以下是根据你的需求制作的宏观经济学名词解释消消乐游戏网页，包含所有要求的功能和视觉效果：

```html
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>名词解释消消乐</title>
    <style>
        /* 全局样式 */
        body {
            margin: 0;
            padding: 20px;
            background-color: #e6f9e6; /* 淡绿色背景 */
            font-family: 'Microsoft Yahei', sans-serif;
            overflow-x: hidden;
        }

        /* 标题样式 */
        h1 {
            text-align: center;
            color: #2d882d;
            font-size: 3rem;
            margin-bottom: 40px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        /* 游戏容器 */
        .game-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 25px;
            max-width: 1300px;
            margin: 0 auto;
        }

        /* 泡泡样式 */
        .bubble {
            width: 280px;
            height: 280px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 25px;
            box-sizing: border-box;
            font-size: 1.4rem;
            font-weight: bold;
            color: #333;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: inset -10px -10px 20px rgba(255,255,255,0.8), 
                        inset 10px 10px 20px rgba(0,0,0,0.1),
                        0 10px 20px rgba(0,0,0,0.1);
            transform: perspective(1000px) rotateX(5deg);
            user-select: none;
        }

        /* 高亮状态 */
        .bubble.highlight {
            transform: perspective(1000px) rotateX(0deg) scale(1.05);
            box-shadow: inset -10px -10px 20px rgba(255,255,255,0.8), 
                        inset 10px 10px 20px rgba(0,0,0,0.1),
                        0 15px 30px rgba(0,128,0,0.3);
            border: 3px solid #2d882d;
        }

        /* 结果提示 */
        .congratulations {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background-color: white;
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            font-size: 2.5rem;
            font-weight: bold;
            color: #2d882d;
            text-align: center;
            z-index: 1000;
            display: none;
            animation: popIn 0.5s ease-out forwards;
        }

        @keyframes popIn {
            0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
            80% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
            100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
        }

        /* 烟花容器 */
        .fireworks {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 999;
        }

        .firework {
            position: absolute;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            animation: fireworkRise 1.5s ease-out forwards;
        }

        .spark {
            position: absolute;
            width: 4px;
            height: 4px;
            border-radius: 50%;
            animation: sparkFly 0.6s ease-out forwards;
        }

        @keyframes fireworkRise {
            0% {
                transform: translateY(100vh) scale(0);
                opacity: 1;
            }
            50% {
                transform: translateY(calc(50vh - 100px)) scale(1);
                opacity: 1;
            }
            100% {
                transform: translateY(0) scale(0);
                opacity: 0;
            }
        }

        @keyframes sparkFly {
            0% {
                transform: translateX(0) translateY(0);
                opacity: 1;
            }
            100% {
                transform: translateX(var(--x)) translateY(var(--y));
                opacity: 0;
            }
        }
    </style>
</head>
<body>
    <h1>名词解释消消乐</h1>
    <div class="game-container" id="gameContainer"></div>
    <div class="congratulations" id="congratulations">恭喜挑战成功！🎉</div>
    <div class="fireworks" id="fireworks"></div>

    <script>
        // 游戏数据：名词和对应的解释
        const termPairs = [
            { term: "国民收入（NI）", definition: "从国内生产净值中扣除间接税和企业转移支付，加政府补助金后的收入" },
            { term: "国内生产净值（NDP）", definition: "从国内生产总值中扣除折旧后的产值" },
            { term: "个人可支配收入（DPI）", definition: "个人缴纳个人所得税后剩余的可自由支配的收入" },
            { term: "国内生产总值（GDP）", definition: "一国境内一定时期内生产的所有最终产品和服务的市场价值总和" },
            { term: "国民生产总值（GNP）", definition: "一国居民在一定时期内所拥有的全部生产要素生产的最终产品市场价值总和" }
        ];

        // 生成所有泡泡元素（名词+解释）
        let allBubbles = [];
        termPairs.forEach(pair => {
            allBubbles.push({ type: 'term', content: pair.term, match: pair.definition });
            allBubbles.push({ type: 'definition', content: pair.definition, match: pair.term });
        });

        // 打乱数组顺序
        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
            return array;
        }

        allBubbles = shuffleArray(allBubbles);

        const gameContainer = document.getElementById('gameContainer');
        const congratulations = document.getElementById('congratulations');
        const fireworksContainer = document.getElementById('fireworks');

        let selectedBubble = null;

        // 创建泡泡元素
        function createBubble(item) {
            const bubble = document.createElement('div');
            bubble.className = 'bubble';
            bubble.textContent = item.content;
            bubble.dataset.match = item.match;
            
            // 随机浅色背景（柔和色调）
            const hue = Math.floor(Math.random() * 360);
            bubble.style.backgroundColor = `hsl(${hue}, 25%, 88%)`;

            // 点击事件
            bubble.addEventListener('click', () => {
                if (selectedBubble === bubble) {
                    // 取消高亮
                    bubble.classList.remove('highlight');
                    selectedBubble = null;
                    return;
                }

                if (!selectedBubble) {
                    // 第一个点击的泡泡
                    selectedBubble = bubble;
                    bubble.classList.add('highlight');
                } else {
                    // 第二个点击的泡泡，判断是否匹配
                    if (selectedBubble.dataset.match === bubble.textContent) {
                        // 匹配成功，移除两个泡泡
                        selectedBubble.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                        bubble.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                        selectedBubble.style.opacity = '0';
                        selectedBubble.style.transform = 'scale(0.8)';
                        bubble.style.opacity = '0';
                        bubble.style.transform = 'scale(0.8)';
                        setTimeout(() => {
                            selectedBubble.remove();
                            bubble.remove();
                            // 检查是否所有泡泡都消失
                            checkWin();
                        }, 300);
                    } else {
                        // 匹配失败，取消高亮并添加抖动效果
                        selectedBubble.classList.remove('highlight');
                        selectedBubble.style.animation = 'shake 0.5s ease';
                        bubble.style.animation = 'shake 0.5s ease';
                        setTimeout(() => {
                            selectedBubble.style.animation = '';
                            bubble.style.animation = '';
                        }, 500);
                    }
                    selectedBubble = null;
                }
            });

            return bubble;
        }

        // 添加抖动动画
        const style = document.createElement('style');
        style.textContent = `
            @keyframes shake {
                0%, 100% { transform: perspective(1000px) rotateX(5deg) translateX(0); }
                25% { transform: perspective(1000px) rotateX(5deg) translateX(-10px); }
                75% { transform: perspective(1000px) rotateX(5deg) translateX(10px); }
            }
        `;
        document.head.appendChild(style);

        // 初始化游戏
        function initGame() {
            allBubbles.forEach(item => {
                gameContainer.appendChild(createBubble(item));
            });
        }

        // 检查是否获胜
        function checkWin() {
            if (gameContainer.children.length === 0) {
                congratulations.style.display = 'block';
                launchFireworks();
            }
        }

        // 生成烟花效果
        function launchFireworks() {
            const colors = ['#ff4444', '#ffbb33', '#00C851', '#33b5e5', '#aa66cc', '#ff4444'];
            
            for (let i = 0; i < 25; i++) {
                setTimeout(() => {
                    const firework = document.createElement('div');
                    firework.className = 'firework';
                    const color = colors[Math.floor(Math.random() * colors.length)];
                    firework.style.backgroundColor = color;
                    firework.style.left = `${Math.random() * 100}%`;
                    firework.style.animationDelay = `${Math.random() * 1}s`;
                    fireworksContainer.appendChild(firework);

                    // 烟花爆炸效果
                    setTimeout(() => {
                        for (let j = 0; j < 25; j++) {
                            const spark = document.createElement('div');
                            spark.className = 'spark';
                            spark.style.backgroundColor = color;
                            spark.style.left = firework.style.left;
                            spark.style.top = '50%';
                            const angle = (j / 25) * Math.PI * 2;
                            const distance = 50 + Math.random() * 100;
                            spark.style.setProperty('--x', `${Math.cos(angle) * distance}px`);
                            spark.style.setProperty('--y', `${Math.sin(angle) * distance}px`);
                            spark.style.animationDelay = `${Math.random() * 0.3}s`;
                            fireworksContainer.appendChild(spark);

                            // 移除火花
                            setTimeout(() => spark.remove(), 600);
                        }
                        firework.remove();
                    }, 1200);
                }, i * 150);
            }
        }

        // 启动游戏
        initGame();
    </script>
</body>
</html>
```

### 游戏特点：
1. **视觉设计**：
   - 淡绿色背景，清新护眼
   - 3D立体泡泡效果，带有内外阴影和透视旋转
   - 随机柔和浅色泡泡背景，保持视觉舒适度
   - 大字体加粗显示内容，确保可读性

2. **交互体验**：
   - 点击泡泡会高亮显示，方便识别选中状态
   - 配对成功时泡泡会平滑缩小消失
   - 配对失败时泡泡会产生抖动效果提示错误
   - 所有泡泡配对完成后显示恭喜弹窗并播放烟花动画

3. **游戏逻辑**：
   - 名词和解释一一对应，不会重复出现
   - 点击两个泡泡进行配对，正确则消失，错误则保持
   - 自动检测所有泡泡是否消失，触发胜利条件

你可以直接将这段代码保存为HTML文件，用浏览器打开即可开始游戏。游戏完全适配桌面端，泡泡大小和间距都经过优化，确保良好的游戏体验。